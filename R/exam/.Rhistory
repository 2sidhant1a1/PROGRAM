name <- c("Mandi", "Amy", "Nicole", "Olivia")
distance <- c(0.8, 3.1, 2.8, 4.0)
time <- c(10, 30, 40, 50)
time <- time/60
speed <- distance/time
table(distance,time,speed)
View(distance,time,speed)
data <- data.frame(distance, time, speed)
View(data)
data <- data.frame(name,distance, time, speed)
view(data)
View(data)
library(dslabs)
data(olive)
head(olive)
View(olive)
scatter.smooth(olive$palmitic,olive$palmitoleic)
hist.default(olive$eicosenoic)
boxplot(olive$palmitic)
boxplot.default(olive$palmitic)
boxplot(palmitic ~ region,
data = olive,
xlab = "Region",
ylab = "Palmitic Acid (%)",
main = "Palmitic Acid by Region")
boxplot(palmitic ~ region,data = olive, xlab = "Region", ylab = "Palmitic Acid(%)", main = "Palmitic Acid by Region")
